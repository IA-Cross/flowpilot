# FlowPilot — environment variable template
# Copy to infra/.env and fill in real values. NEVER commit .env to git.

# --- Database ---
DB_NAME=flowpilot
DB_USER=flowpilot
DB_PASS=change_me_strong_password

# --- Redis ---
# No auth by default; add REDIS_PASS for production
REDIS_PASS=

# --- Security (REQUIRED in production) ---
# Generate with:  openssl rand -base64 64
JWT_SECRET=CHANGE_ME_use_a_strong_256bit_secret_here

# AES-GCM master key for encrypting channel secrets at rest (base64 256-bit key)
# Generate with:  openssl rand -base64 32
ENCRYPTION_MASTER_KEY=CHANGE_ME

# --- Telegram (Phase 1) ---
# Bot token from BotFather. NEVER commit. Stored in DB only as AES-GCM ciphertext.
# Set via POST /api/v1/channels/telegram — do not put in application.yml.
TELEGRAM_BOT_TOKEN=CHANGE_ME_your_bot_token_here

# Webhook base URL used by Telegram to POST updates (e.g. your ngrok tunnel for local dev)
# Example: https://abc123.ngrok-free.app
TELEGRAM_WEBHOOK_BASE_URL=https://your-domain.example.com

# Telegram API base URL (override only for testing; leave default for production)
# TELEGRAM_BASE_URL=https://api.telegram.org

# --- Spring profile ---
SPRING_PROFILES_ACTIVE=local
